# Frontend
NODE_ENV=production
PORT=3000
BACKEND_URL=http://backend:8080
VITE_SITE_URL=https://clawhub.example.com
VITE_API_BASE=/api/v1
VITE_API_BASE_URL=https://api.clawhub.example.com/api/v1
VITE_BACKEND_BASE=
VITE_CLI_NPM_REGISTRY=https://registry.npmjs.org
VITE_CLI_PACKAGE_NAME=clawhub@latest
VITE_CLI_SKILL_REGISTRY=https://api.clawhub.example.com
API_ORIGIN=https://api.clawhub.example.com

# Backend
GO_ENV=pro
DATABASE_URL=postgres://clawhub:password@postgres:5432/clawhub?sslmode=disable
DATABASE_MAX_CONNECTIONS=25
JWT_SECRET=replace-with-a-long-random-secret
FRONTEND_URL=https://clawhub.example.com
OSS_ENDPOINT=s3.example.com
OSS_BUCKET=clawhub
OSS_REGION=cn-east-1
OSS_ACCESS_KEY_ID=replace-me
OSS_ACCESS_KEY_SECRET=replace-me

# Optional auth providers
GITHUB_ENABLED=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITLAB_ENABLED=false
GITLAB_BASE_URL=
GITLAB_DISCOVERY_URL=
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_IMPORT_TOKEN=
GITLAB_CA_CERT_FILE=
GITLAB_ALLOWED_GROUPS=
ALLOWED_EMAIL_DOMAINS=
AUTH_SUPERUSERS_JSON=[]
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
